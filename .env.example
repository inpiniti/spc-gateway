# Gateway Configuration (optional)
TCP_PORT=5070
HTTP_PORT=3001
DB_PATH=./db.json

# spc-api 연동 (명령 큐 polling / 알람·상태·연간압력 보고)
API_BASE_URL=http://127.0.0.1:3000/api/v1
GATEWAY_KEY=gw_secret_key_change_me
GATEWAY_ID=gw-local-01
POLL_INTERVAL_MS=5000
POLL_LIMIT=10
RESULT_TIMEOUT_MS=30000

# PostgreSQL sink — 700 정주기 데이터 직접 INSERT 전용 (701/상태/명령은 API 경유)
PG_ENABLED=true
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=spcdb
PGUSER=spc
PGPASSWORD=1234
